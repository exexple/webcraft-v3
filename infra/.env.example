# ─────────────────────────────────────────────────────────────
# WEBCRAFT STUDIO — Master Environment Template
# Copy this to each service's .env and fill in real values
# ─────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Admin credentials (hashed with bcrypt in the gateway)
ADMIN_EMAIL=admin@webcraftstudio.com
ADMIN_PASSWORD_HASH=your-bcrypt-hashed-password

# ── Gateway ──────────────────────────────────────────────────
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0

# ── Service URLs (used by Gateway) ───────────────────────────
LEADS_SERVICE_URL=http://localhost:4001
ANALYTICS_SERVICE_URL=http://localhost:4002
CMS_SERVICE_URL=http://localhost:4003

# ── Service Ports ────────────────────────────────────────────
LEADS_SERVICE_PORT=4001
ANALYTICS_SERVICE_PORT=4002
CMS_SERVICE_PORT=4003

# ── IP Hashing Salt (for anonymized analytics) ───────────────
IP_HASH_SALT=your-random-salt-value-here

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:4000/api
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Wildcards (*) are supported.
# Production example: https://webcraftstudio.com,https://*.vercel.app
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development
