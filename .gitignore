# Webcraft Studio — Monorepo .gitignore

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ──────────────────────────────
dist/
.next/
out/
build/
*.tsbuildinfo

# ── Environment files ──────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
infra/.env.local
infra/.env.production

# ── Logs ──────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS / Editor ───────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
*.swp
*.swo

# ── Turbo ─────────────────────────────────────
.turbo/

# ── Misc ──────────────────────────────────────
coverage/
.nyc_output/
*.tgz
