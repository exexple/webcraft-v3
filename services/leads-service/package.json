{
  "name": "@webcraft/leads-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../infra/.env src/server.ts",
    "build": "tsc",
