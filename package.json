{
  "name": "webcraft-studio",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "frontend",
    "gateway",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "turbo run dev",
